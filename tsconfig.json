{

    "$schema": "https://json.schemastore.org/tsconfig",

    /******************** Root Fields | https://www.typescriptlang.org/tsconfig/#root-fields ********************/

    // "files": [],
    // "extends": "",
    // "include": [],
    "exclude": [
        ".cache",
        ".idea",
        ".git",
        ".github",
        ".temp",
        "build",
        "bower_components",
        "dist",
        "jspm_packages",
        "node_modules",
        "out",
        "temp",
        "web_packages"
    ],
    // "references": [],

    /******************** Compiler Options | https://www.typescriptlang.org/tsconfig/#compiler-options ********************/

    "compilerOptions": {

        /*-------------------- Type Checking --------------------*/

        // "allowUnreachableCode": null,
        // "allowUnusedLabels": null,
        // "alwaysStrict": false, // <-- Defaults to `true` when `strict` is true
        "exactOptionalPropertyTypes": false,
        "noFallthroughCasesInSwitch": true,
        // "noImplicitAny": false, // <-- Defaults to `true` when `strict` is true
        "noImplicitOverride": true,
        // "noImplicitReturns": false,
        // "noImplicitThis": false, // <-- Defaults to `true` when `strict` is true
        // "noPropertyAccessFromIndexSignature": false,
        "noUncheckedIndexedAccess": true,
        // "noUnusedLocals": false,
        // "noUnusedParameters": false,
        "strict": true,
        // "strictBindCallApply": false, // <-- Defaults to `true` when `strict` is true
        // "strictBuiltinIteratorReturn": false, // <-- Defaults to `true` when `strict` is true
        // "strictFunctionTypes": false, // <-- Defaults to `true` when `strict` is true
        // "strictNullChecks": false, // <-- Defaults to `true` when `strict` is true
        // "strictPropertyInitialization": false, // <-- Defaults to `true` when `strict` is true
        // "useUnknownInCatchVariables": false, // <-- Defaults to `true` when `strict` is true

        /*-------------------- Modules --------------------*/

        "allowArbitraryExtensions": false,
        "allowImportingTsExtensions": false,
        // "allowUmdGlobalAccess": false,
        // "baseUrl": "./",
        // "customConditions": null,
        "module": "ES2022",
        "moduleResolution": "nodenext",
        "moduleSuffixes": [ "" ],
        // "noResolve": false,
        "noUncheckedSideEffectImports": false,
        // "paths": {},
        "resolveJsonModule": true,
        // "resolvePackageJsonExports": false, // <-- Defaults to `true` when `moduleResolution` is node16, nodenext, or bundler
        // "resolvePackageJsonImports": false, // <-- Defaults to `true` when `moduleResolution` is node16, nodenext, or bundler
        "rewriteRelativeImportExtensions": true,
        // "rootDir": "./",
        // "rootDirs": [],
        // "typeRoots": [],
        // "types": [],

        /*-------------------- Emit --------------------*/

        "declaration": true,
        // "declarationDir": "./",
        "declarationMap": true,
        // "downlevelIteration": false,
        // "emitBOM": false,
        // "emitDeclarationOnly": false,
        "importHelpers": true,
        // "inlineSourceMap": false,
        "inlineSources": true,
        // "mapRoot": "",
        "newLine": "lf",
        // "noEmit": false,
        // "noEmitHelpers": false,
        "noEmitOnError": true,
        // "outDir": "./",
        // "outFile": "./",
        "preserveConstEnums": true,
        // "removeComments": false,
        "sourceMap": true,
        // "sourceRoot": "",
        "stripInternal": true,

        /*-------------------- JavaScript Support --------------------*/

        "allowJs": true,
        // "checkJs": false,
        // "maxNodeModuleJsDepth": 0,

        /*-------------------- Editor Support --------------------*/

        "disableSizeLimit": true,
        // "plugins": [],

        /*-------------------- Interop Constraints --------------------*/

        // "allowSyntheticDefaultImports": null,
        // "erasableSyntaxOnly": false,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        // "isolatedDeclarations": null,
        // "isolatedModules": false,
        // "preserveSymlinks": false,
        "verbatimModuleSyntax": true,

        /******************** Backwards Compatibility ********************/

        // "charset": "utf8", // <---- deprecated
        // "importsNotUsedAsValues": "remove", // <---- deprecated
        // "keyofStringsOnly": false, // <---- deprecated
        // "noImplicitUseStrict": false,
        // "noStrictGenericChecks": false,
        // "out": false, // <---- deprecated (use `outFile` instead)
        // "preserveValueImports": true, // <---- deprecated
        // "suppressExcessPropertyErrors": false,
        // "suppressImplicitAnyIndexErrors": false,

        /******************** Language and Environment ********************/

        // "emitDecoratorMetadata": false,
        // "experimentalDecorators": false,
        // "jsx": "react",
        // "jsxFactory": "React.createElement",
        // "jsxFragmentFactory": "React.Fragment",
        // "jsxImportSource": "react",
        // "lib": [],
        "libReplacement": false,
        "moduleDetection": "force",
        // "noLib": false,
        // "reactNamespace": "React", // Use `jsxFactory` instead
        "target": "es2022",
        // "useDefineForClassFields": false,

        /******************** Compiler Diagnostics ********************/

        // "diagnostics": false, // <---- deprecated
        // "explainFiles": null,
        // "extendedDiagnostics": false,
        // "generateCpuProfile": "profile.cpuprofile", // CLI-only option (e.g. `tsc --generateCpuProfile tsc-output.cpuprofile`)
        // "generateTrace": false,
        "listEmittedFiles": true,
        // "listFiles": false,
        // "noCheck": false,
        // "traceResolution": false,

        /******************** Projects ********************/

        // "composite": false,
        // "disableReferencedProjectLoad": null,
        // "disableSolutionSearching": false,
        // "disableSourceOfProjectReferenceRedirect": false,
        // "incremental": false,
        // "tsBuildInfoFile": ".tsbuildinfo",

        /******************** Output Formatting ********************/

        // "noErrorTruncation": false,
        // "preserveWatchOutput": false,
        // "pretty": true,

        /******************** Completeness ********************/

        // "skipDefaultLibCheck": false, // Use `skipLibCheck` instead
        // "skipLibCheck": false,

        /******************** Watch Options (built-in to the lib maybe?) ********************/

        // "assumeChangesOnlyAffectDirectDependencies": false,

    },

    /******************** Watch Options | https://www.typescriptlang.org/tsconfig/#watchOptions ********************/

    "watchOptions": {

        // "watchFile": "useFsEvents",
        // "watchDirectory": "useFsEvents",
        // "fallbackPolling": null,
        // "synchronousWatchDirectory": null,
        // "excludeDirectories": null,
        // "excludeFiles": null,

    },

    /******************** Type Acquisition | https://www.typescriptlang.org/tsconfig/#typeAcquisition ********************/

    "typeAcquisition": {
        "enable": false,
        "include": [],
        "exclude": [],
        "disableFilenameBasedTypeAcquisition": true,
    },

}
